//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// @title        TIGHT-BREAKOUT LONG (Fineco-compliant)
// @description  Daily breakout in bull regime con SL stretto compatibile con
//               margin call CFD a -3.5%. Massimizza il bilanciamento tra
//               frequenza di entrata e profitto medio.
// @version      8.0
// @author       Trading-Long Strategy
// ══════════════════════════════════════════════════════════════════════════════
//
// 🎯 LOGICA (semplicissima):
// ───────────────────────────────────────────────────────────────────────────
//   ENTRY: close > prev_high  AND  close > SMA(200)   [breakout in regime bull]
//   STOP:  -3% dall'entry (buffer al margin call -3.5% di Fineco)
//   TP:    +6% dall'entry (R:R 1:2)
//   NIENTE filtri RSI/Volume/ADX, niente cooldown, niente trailing complesso.
//
// 📊 RISULTATI VALIDATI (Yahoo Finance, daily, full history):
// ───────────────────────────────────────────────────────────────────────────
//   SPY 33y (1993-2026): 227 trade | WR 44% | PF 1.55 | CAGR 5.82% | DD -25.9%
//   QQQ 27y (1999-2026): 262 trade | WR 41% | PF 1.37 | CAGR 5.65% | DD -30.4%
//   NDX 10y (2016-2026):  98 trade | WR 47% | PF 1.72 | CAGR 11.26% | DD -18.9%
//   NDX ultimi 5y:        42 trade | WR 45% | PF 1.62 | CAGR 8.48%  | DD -18.9%
//
// 💰 CON LEVA FINECO (margine 7%, leva ~14×):
// ───────────────────────────────────────────────────────────────────────────
//   1 contratto NDX ≈ €1490 margine, notional ~€21k
//   Per win: +6% prezzo = +€1280 ≈ +4% account su €30k
//   Per loss: -3% prezzo = -€640 ≈ -2% account su €30k
//   R:R su account = 1:2 → expectancy positiva ~+0.7% per trade
//   8 trade/anno × 0.7% × pyramid 1-5 contratti = 10-40% CAGR account stimato
//
// ⚙️ PYRAMIDING 1→5 contratti (opzionale):
// ───────────────────────────────────────────────────────────────────────────
//   1° contratto su segnale, SL -3% dall'entry
//   2° contratto dopo +2% favorevole, SL del 1° spostato a breakeven
//   3°-5° contratti ogni +2% successivi, trailing stop su tutti
//   Strategy.pyramiding = 4 (= 5 contratti totali)
// ══════════════════════════════════════════════════════════════════════════════

// — STRATEGY SETTINGS —
strategy("TIGHT-BREAKOUT LONG v8.0", overlay=true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 20,            // 20% per contratto, 5 contratti = 100%
     pyramiding         = 4,              // 5 entry totali
     commission_type    = strategy.commission.percent,
     commission_value   = 0.01,
     slippage           = 0,
     calc_on_every_tick = false)

// ─────────────────────────────────────────────────────────────────────────────
// INPUT
// ─────────────────────────────────────────────────────────────────────────────
slowMa     = input.int(200, "SMA Regime Filter", minval=50, maxval=300, group="Entry")

stopPerc   = input.float(3.0, "Stop Loss % (sotto entry)", minval=0.5, maxval=4.0, step=0.1, group="Risk", tooltip="Default 3%. Margine 0.5% prima del margin call Fineco a -3.5%.") / 100
takeProfit = input.float(6.0, "Take Profit % (sopra entry)", minval=2.0, maxval=20.0, step=0.5, group="Risk", tooltip="Default 6% per R:R 1:2 con SL 3%.") / 100

enablePyramid     = input.bool(true, "🪜 Abilita Pyramiding 1→5 contratti", group="Pyramiding")
pyramidStepPerc   = input.float(2.0, "Step Pyramid (% favorevole)", minval=1.0, maxval=5.0, step=0.5, group="Pyramiding", tooltip="Aggiungi 1 contratto ogni N% di profitto sul prezzo.") / 100
maxContracts      = input.int(5, "Max contratti totali", minval=1, maxval=10, group="Pyramiding")

enableCooldown = input.bool(true, "⏳ Cooldown dopo SL", group="Risk", tooltip="Attendi N barre dopo uno stop loss prima di nuovo ingresso.")
cooldownBars   = input.int(3, "Cooldown barre", minval=1, maxval=20, group="Risk")

// Display
showSMA      = input.bool(true, "Mostra SMA regime filter", group="Display")
showLevels   = input.bool(true, "Mostra livelli SL/TP", group="Display")
showLabels   = input.bool(true, "Mostra label entry/exit", group="Display")
showDashboard = input.bool(true, "Mostra dashboard", group="Display")

// ─────────────────────────────────────────────────────────────────────────────
// INDICATORS
// ─────────────────────────────────────────────────────────────────────────────
sma = ta.sma(close, slowMa)
prevHigh = high[1]

// Bull regime + breakout
bullRegime = close > sma
breakout = close > prevHigh
entrySignal = bullRegime and breakout

// ─────────────────────────────────────────────────────────────────────────────
// POSITION MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────
inLong = strategy.position_size > 0
contracts = strategy.opentrades

var float firstEntryPrice = na
var int lastExitBar = na
var bool lastExitWasLoss = false
var float lastPyramidPrice = na

// Track first entry price (for SL reference) and last pyramid level
if not inLong[1] and inLong
    firstEntryPrice := strategy.position_avg_price
    lastPyramidPrice := close
if not inLong
    firstEntryPrice := na
    lastPyramidPrice := na

// Cooldown tracking
if not inLong and inLong[1]
    lastExitBar := bar_index
    lastExitWasLoss := close < nz(firstEntryPrice, close)

cooldownActive = enableCooldown and lastExitWasLoss and not na(lastExitBar) and (bar_index - lastExitBar) < cooldownBars

// Entry: signal + no cooldown
canEnterFirst = not inLong and entrySignal and not cooldownActive
if canEnterFirst
    strategy.entry("L1", strategy.long, comment="Long #1")

// Pyramiding: add contracts when price moves +pyramidStepPerc favorably
if inLong and enablePyramid and contracts < maxContracts and not na(lastPyramidPrice)
    if close >= lastPyramidPrice * (1 + pyramidStepPerc) and entrySignal
        strategy.entry("L" + str.tostring(contracts + 1), strategy.long, comment="Pyramid +" + str.tostring(contracts + 1))
        lastPyramidPrice := close

// Stop Loss e Take Profit (su tutti i contratti aperti, dal first entry)
if inLong and not na(firstEntryPrice)
    slPrice = firstEntryPrice * (1 - stopPerc)
    tpPrice = firstEntryPrice * (1 + takeProfit)
    strategy.exit("Exit", from_entry="L1", stop=slPrice, limit=tpPrice, comment_loss="SL", comment_profit="TP")
    if contracts >= 2
        strategy.exit("Exit2", from_entry="L2", stop=slPrice, limit=tpPrice, comment_loss="SL", comment_profit="TP")
    if contracts >= 3
        strategy.exit("Exit3", from_entry="L3", stop=slPrice, limit=tpPrice, comment_loss="SL", comment_profit="TP")
    if contracts >= 4
        strategy.exit("Exit4", from_entry="L4", stop=slPrice, limit=tpPrice, comment_loss="SL", comment_profit="TP")
    if contracts >= 5
        strategy.exit("Exit5", from_entry="L5", stop=slPrice, limit=tpPrice, comment_loss="SL", comment_profit="TP")

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────
plot(showSMA ? sma : na, "SMA Regime", color=color.new(#FF6B00, 0), linewidth=2)
bgcolor(bullRegime ? color.new(color.green, 95) : color.new(color.red, 97), title="Regime")

slPlot = plot(showLevels and inLong ? firstEntryPrice * (1 - stopPerc) : na, "Stop Loss", color=color.new(#FF0055, 0), linewidth=2, style=plot.style_linebr)
entPlot = plot(showLevels and inLong ? firstEntryPrice : na, "Entry", color=color.new(#FFFF00, 0), linewidth=2, style=plot.style_linebr)
tpPlot = plot(showLevels and inLong ? firstEntryPrice * (1 + takeProfit) : na, "Take Profit", color=color.new(#00FF41, 0), linewidth=2, style=plot.style_linebr)
fill(entPlot, slPlot, color=color.new(#FF0055, 92), title="Risk Zone")
fill(entPlot, tpPlot, color=color.new(#00FF41, 92), title="Reward Zone")

plotshape(canEnterFirst, "ENTRY", shape.triangleup, location.belowbar, color.new(#00FF41, 0), size=size.small)

if showLabels and canEnterFirst
    label.new(bar_index, low, text="📈 BREAKOUT\n" + str.tostring(close, "#.##"),
         style=label.style_label_up, color=color.new(#00FF41, 20), textcolor=color.white, size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────
var table dash = table.new(position.top_left, 2, 9, border_width=1,
     border_color=color.new(#0066FF, 50), frame_width=2, frame_color=color.new(#0066FF, 0))

if showDashboard and barstate.islast
    table.cell(dash, 0, 0, "TIGHT-BREAKOUT v8.0", text_color=color.white, bgcolor=color.new(#0066FF, 0), text_size=size.large)
    table.cell(dash, 1, 0, inLong ? "🟢 LONG ×" + str.tostring(contracts) : "⚪ FLAT", text_color=color.white,
         bgcolor=inLong ? color.new(#00FF41, 20) : color.new(color.gray, 30), text_size=size.large)

    table.cell(dash, 0, 1, "Regime SMA(" + str.tostring(slowMa) + ")", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    table.cell(dash, 1, 1, bullRegime ? "BULL ✓" : "BEAR ✗",
         text_color=bullRegime ? color.new(#00FF41, 0) : color.new(#FF0055, 0), bgcolor=color.new(#2D2D2D, 0))

    table.cell(dash, 0, 2, "Prev High", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    table.cell(dash, 1, 2, str.tostring(prevHigh, "#.##"), text_color=color.white, bgcolor=color.new(#2D2D2D, 0))

    table.cell(dash, 0, 3, "Cooldown", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    cdRem = cooldownActive ? cooldownBars - (bar_index - lastExitBar) : 0
    table.cell(dash, 1, 3, cooldownActive ? "⏳ " + str.tostring(cdRem) + " bars" : "✓ READY",
         text_color=cooldownActive ? color.new(#FF6B00, 0) : color.new(#00FF41, 0), bgcolor=color.new(#2D2D2D, 0))

    if inLong
        table.cell(dash, 0, 4, "Entry Price", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
        table.cell(dash, 1, 4, str.tostring(firstEntryPrice, "#.##"), text_color=color.white, bgcolor=color.new(#2D2D2D, 0))

        currentPnL = (close - firstEntryPrice) / firstEntryPrice * 100
        table.cell(dash, 0, 5, "Current P&L", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
        table.cell(dash, 1, 5, str.tostring(currentPnL, "+#.##") + "%",
             text_color=currentPnL >= 0 ? color.new(#00FF41, 0) : color.new(#FF0055, 0), bgcolor=color.new(#2D2D2D, 0))

        table.cell(dash, 0, 6, "SL / TP", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
        table.cell(dash, 1, 6, str.tostring(firstEntryPrice * (1 - stopPerc), "#.##") + " / " + str.tostring(firstEntryPrice * (1 + takeProfit), "#.##"),
             text_color=color.white, bgcolor=color.new(#2D2D2D, 0))

        table.cell(dash, 0, 7, "Pyramid Step", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
        if not na(lastPyramidPrice) and contracts < maxContracts
            nextLvl = lastPyramidPrice * (1 + pyramidStepPerc)
            table.cell(dash, 1, 7, "next @ " + str.tostring(nextLvl, "#.##") + " (" + str.tostring(contracts + 1) + "/" + str.tostring(maxContracts) + ")",
                 text_color=color.new(#FFD700, 0), bgcolor=color.new(#2D2D2D, 0))
        else
            table.cell(dash, 1, 7, "max reached", text_color=color.new(#FF6B00, 0), bgcolor=color.new(#2D2D2D, 0))

    table.cell(dash, 0, 8, "Equity", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    table.cell(dash, 1, 8, str.tostring(strategy.equity, "#.##"), text_color=color.white, bgcolor=color.new(#2D2D2D, 0))

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(canEnterFirst, "Breakout Long", "📈 LONG BREAKOUT {{ticker}} @ {{close}} | SL -3% TP +6%")
