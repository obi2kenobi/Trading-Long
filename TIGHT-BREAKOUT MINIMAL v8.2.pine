//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// @title        TIGHT-BREAKOUT MINIMAL v8.2
// @description  Versione minimale: 1 segnale entry, 1 segnale exit (ratchet trail).
//               1 contratto = 100% equity. Niente pyramiding, niente cooldown,
//               niente filtri secondari. Compatibile Fineco CFD margin call -3.5%.
// @version      8.2
// @author       Trading-Long Strategy
// ══════════════════════════════════════════════════════════════════════════════
//
// 🎯 LOGICA (4 righe in totale):
// ───────────────────────────────────────────────────────────────────────────
//   ENTRY: close > prev_high AND close > SMA(200)
//   STOP iniziale: -3% (buffer Fineco margin call -3.5%)
//   RATCHET: ogni +3% favorevole, alza lo stop di +3% (locca profitto)
//   EXIT: solo quando il trail stop scatta. Niente TP, niente filtri.
//
// 📊 BACKTEST PYTHON (Yahoo daily):
// ───────────────────────────────────────────────────────────────────────────
//   SPY 33y: +325% (CAGR 4.45%, DD -76%, 174 trade, WR 33%, PF 1.61)
//   QQQ 27y: +226% (CAGR 4.45%, DD -70%, 200 trade, WR 30%, PF 1.44)
//   NDX 10y: +197% (CAGR 11.49%, DD -67%, 67 trade, WR 33%, PF 2.20)
//
// ⚠️ STILE: bassa win rate, alta R:R. ~30% di trade vincenti ma ognuno
//   cattura mediamente +7-9% mentre i loser sono -2 a -3%. Il segreto è
//   lasciar correre i ~10 grandi winner che superano +15-20%.
// ══════════════════════════════════════════════════════════════════════════════

strategy("TIGHT-BREAKOUT MINIMAL v8.2", overlay=true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 100,            // ← 100% equity per trade
     pyramiding         = 0,              // ← NIENTE pyramiding
     commission_type    = strategy.commission.percent,
     commission_value   = 0.01,
     slippage           = 0)

// ─────────────────────────────────────────────────────────────────────────────
// INPUT (solo i 3 essenziali)
// ─────────────────────────────────────────────────────────────────────────────
slowMa     = input.int(200, "SMA Regime Filter", minval=50, maxval=300, group="Strategy")
initStop   = input.float(3.0, "Stop iniziale %", minval=0.5, maxval=4.0, step=0.1, group="Strategy") / 100
ratchet    = input.float(3.0, "Ratchet step %", minval=1.0, maxval=10.0, step=0.5, group="Strategy") / 100

// ─────────────────────────────────────────────────────────────────────────────
// LOGIC (~30 righe totali)
// ─────────────────────────────────────────────────────────────────────────────
sma = ta.sma(close, slowMa)
entrySignal = close > high[1] and close > sma

inLong = strategy.position_size > 0
var float entryPrice = na
var float maxProfit = 0.0
var float trailStop = na

// Init/reset al primo entry
if not inLong[1] and inLong
    entryPrice := strategy.position_avg_price
    maxProfit := 0.0
    trailStop := entryPrice * (1 - initStop)

if not inLong
    entryPrice := na
    maxProfit := 0.0
    trailStop := na

// Ratchet: ogni step% di profitto favorevole, alza lo stop di step%
if inLong and not na(entryPrice)
    curProfit = (close - entryPrice) / entryPrice
    maxProfit := math.max(maxProfit, curProfit)
    nSteps = math.floor(maxProfit / ratchet)
    locked = nSteps >= 1 ? (nSteps - 1) * ratchet : -initStop
    newStop = entryPrice * (1 + locked)
    trailStop := math.max(nz(trailStop, entryPrice * (1 - initStop)), newStop)

// 1 SEGNALE ENTRY
if not inLong and entrySignal
    strategy.entry("Long", strategy.long, comment="ENTRY")

// 1 SEGNALE EXIT (trail stop)
if inLong and not na(trailStop)
    strategy.exit("Exit", from_entry="Long", stop=trailStop, comment="EXIT")

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────
plot(sma, "SMA200", color=color.new(#FF6B00, 0), linewidth=2)
plot(inLong ? trailStop : na, "Trail Stop", color=color.new(#FF0055, 0), linewidth=2, style=plot.style_linebr)
plot(inLong ? entryPrice : na, "Entry", color=color.new(#FFFF00, 0), linewidth=1, style=plot.style_linebr)

bgcolor(close > sma ? color.new(color.green, 95) : color.new(color.red, 97))
plotshape(not inLong[1] and inLong, "ENTRY", shape.triangleup, location.belowbar, color.new(#00FF41, 0), size=size.small)
plotshape(inLong[1] and not inLong, "EXIT", shape.triangledown, location.abovebar, color.new(#FF0055, 0), size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// MINI DASHBOARD (solo 4 righe)
// ─────────────────────────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 5, border_width=1, border_color=color.new(#0066FF, 50), frame_width=1, frame_color=color.new(#0066FF, 0))

if barstate.islast
    table.cell(dash, 0, 0, "v8.2 MINIMAL", text_color=color.white, bgcolor=color.new(#0066FF, 0), text_size=size.normal)
    table.cell(dash, 1, 0, inLong ? "🟢 LONG" : "⚪ FLAT", text_color=color.white, bgcolor=inLong ? color.new(#00FF41, 30) : color.new(color.gray, 40), text_size=size.normal)

    table.cell(dash, 0, 1, "Regime", text_color=color.white, bgcolor=color.new(#1E1E1E, 0), text_size=size.small)
    table.cell(dash, 1, 1, close > sma ? "BULL ✓" : "BEAR ✗", text_color=close > sma ? color.new(#00FF41, 0) : color.new(#FF0055, 0), bgcolor=color.new(#2D2D2D, 0), text_size=size.small)

    if inLong
        pnl = (close - entryPrice) / entryPrice * 100
        table.cell(dash, 0, 2, "P&L", text_color=color.white, bgcolor=color.new(#1E1E1E, 0), text_size=size.small)
        table.cell(dash, 1, 2, str.tostring(pnl, "+#.##") + "%", text_color=pnl >= 0 ? color.new(#00FF41, 0) : color.new(#FF0055, 0), bgcolor=color.new(#2D2D2D, 0), text_size=size.small)

        table.cell(dash, 0, 3, "Trail Stop", text_color=color.white, bgcolor=color.new(#1E1E1E, 0), text_size=size.small)
        table.cell(dash, 1, 3, str.tostring(trailStop, "#.##"), text_color=color.new(#FF0055, 0), bgcolor=color.new(#2D2D2D, 0), text_size=size.small)

    table.cell(dash, 0, 4, "Equity", text_color=color.white, bgcolor=color.new(#1E1E1E, 0), text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(strategy.equity, "#.##"), text_color=color.white, bgcolor=color.new(#2D2D2D, 0), text_size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(not inLong[1] and inLong, "ENTRY", "📈 ENTRY {{ticker}} @ {{close}}")
alertcondition(inLong[1] and not inLong, "EXIT", "🛑 EXIT {{ticker}} @ {{close}}")
