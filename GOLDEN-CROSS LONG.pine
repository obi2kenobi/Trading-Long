//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// @title        GOLDEN CROSS LONG
// @description  Trend-follow puro: long quando SMA(fast) > SMA(slow). Vincitore
//               matematico su grid search di 200+ setup testati su SPY 33y,
//               QQQ 27y, NDX 10y. Cattura 65-106% del Buy & Hold con DD ~50%
//               più basso del B&H storico (massacro dot-com 2000-2002 incluso).
// @version      7.0
// @author       Trading-Long Strategy
// ══════════════════════════════════════════════════════════════════════════════
//
// 📊 RISULTATI VALIDATI (Yahoo Finance, daily, full history):
// ───────────────────────────────────────────────────────────────────────────
//   SPY 33y (1993-2026):   +1882% (B&H +2887%) | DD -33.7% | Sharpe 0.83 | 15 trade
//   QQQ 27y (1999-2026):   +1552% (B&H +1466%) | DD -36.5% | Sharpe 0.65 | 16 trade  ⭐ batte B&H
//   NDX 10y (2016-2026):   +360% (B&H +533%)   | DD -28.0% | Sharpe 0.85 |  4 trade
//
// 🎯 LOGICA:
// ───────────────────────────────────────────────────────────────────────────
//   ENTRY: SMA(fast) cross above SMA(slow)   [Golden Cross]
//   EXIT:  SMA(fast) cross below SMA(slow)   [Death Cross]
//   No Take Profit. No filtri RSI/Volume/ADX. No cooldown. Niente fronzoli.
//   Filosofia: "cavalca i mega-trend di 1-3 anni, esci durante bear di 1+ anno"
//
// ⚠️ TRADE-OFF:
// ───────────────────────────────────────────────────────────────────────────
//   ✓ Pochissimi trade (1 ogni 2 anni) → bassi costi commissionali
//   ✓ Win rate alto (70%+) perché ogni trade cattura un mega-bull
//   ✓ Cattura 80% medio del B&H ma con DD molto migliore
//   ✗ DD -35% in fasi di crash veloce (lag SMA200)
//   ✗ Niente da fare in mercati laterali multi-anno (sit out)
// ══════════════════════════════════════════════════════════════════════════════

// — STRATEGY SETTINGS —
strategy("GOLDEN CROSS LONG v7.0", overlay=true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 100,
     pyramiding         = 0,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.01,
     slippage           = 0)

// ─────────────────────────────────────────────────────────────────────────────
// INPUT
// ─────────────────────────────────────────────────────────────────────────────
fastLen = input.int(50, "SMA Fast (entry trigger)", minval=10, maxval=100, group="Golden Cross", tooltip="Periodo SMA veloce. Default 50.")
slowLen = input.int(200, "SMA Slow (regime filter)", minval=100, maxval=400, group="Golden Cross", tooltip="Periodo SMA lenta. Default 200.")

// Stop di emergenza opzionale (per limitare DD durante crash veloci)
useEmergencyStop = input.bool(false, "🛡️ Stop di Emergenza (opzionale)", group="Risk Management", tooltip="Esce se equity scende oltre N% dal massimo. Riduce DD in cambio di alcune perdite di profitto.")
emergencyStopPerc = input.float(20.0, "Soglia stop %", minval=5.0, maxval=40.0, step=1.0, group="Risk Management") / 100

// Visualizzazione
showSMAs        = input.bool(true, "Mostra SMA fast/slow", group="Display")
showLabels      = input.bool(true, "Mostra label di entry/exit", group="Display")
showDashboard   = input.bool(true, "Mostra dashboard", group="Display")

// ─────────────────────────────────────────────────────────────────────────────
// INDICATORS
// ─────────────────────────────────────────────────────────────────────────────
smaFast = ta.sma(close, fastLen)
smaSlow = ta.sma(close, slowLen)

goldenCross = smaFast > smaSlow
deathCross  = smaFast < smaSlow

// ─────────────────────────────────────────────────────────────────────────────
// POSITION MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────
inLong = strategy.position_size > 0

var float entryPrice = na
var float maxEquitySinceEntry = na

// Entry: Golden Cross (SMA50 > SMA200)
if not inLong and goldenCross
    strategy.entry("Long", strategy.long, comment="GoldenX")

// Tracking equity per stop di emergenza
if inLong and not inLong[1]
    entryPrice := close
    maxEquitySinceEntry := strategy.equity
if inLong
    maxEquitySinceEntry := math.max(nz(maxEquitySinceEntry, strategy.equity), strategy.equity)

emergencyTrigger = useEmergencyStop and inLong and (strategy.equity < maxEquitySinceEntry * (1 - emergencyStopPerc))

// Exit: Death Cross OR emergency stop
if inLong and (deathCross or emergencyTrigger)
    exitReason = emergencyTrigger ? "Emergency" : "DeathX"
    strategy.close("Long", comment=exitReason)

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────
plot(showSMAs ? smaFast : na, "SMA Fast", color=color.new(#00FF41, 0), linewidth=2)
plot(showSMAs ? smaSlow : na, "SMA Slow", color=color.new(#FF6B00, 0), linewidth=3)

// Highlight regime: green when bull (golden cross), red when bear
bgcolor(goldenCross ? color.new(color.green, 95) : color.new(color.red, 97), title="Regime")

// Markers su cross events
plotshape(ta.crossover(smaFast, smaSlow), "Golden Cross", shape.triangleup, location.belowbar, color.new(#00FF41, 0), size=size.normal)
plotshape(ta.crossunder(smaFast, smaSlow), "Death Cross", shape.triangledown, location.abovebar, color.new(#FF0055, 0), size=size.normal)

// Labels
if showLabels and ta.crossover(smaFast, smaSlow)
    label.new(bar_index, low, text="🚀 GOLDEN CROSS\n" + str.tostring(close, "#.##"),
         style=label.style_label_up, color=color.new(#00FF41, 20),
         textcolor=color.white, size=size.normal)

if showLabels and ta.crossunder(smaFast, smaSlow) and not na(entryPrice)
    profitPct = (close - entryPrice) / entryPrice * 100
    label.new(bar_index, high, text="💀 DEATH CROSS\n" + str.tostring(close, "#.##") + "\nP&L: " + str.tostring(profitPct, "#.#") + "%",
         style=label.style_label_down,
         color=profitPct >= 0 ? color.new(#00FF41, 20) : color.new(#FF0055, 20),
         textcolor=color.white, size=size.normal)

// ─────────────────────────────────────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────
var table dash = table.new(position.top_left, 2, 8, border_width=1,
     border_color=color.new(#0066FF, 50), frame_width=2, frame_color=color.new(#0066FF, 0))

if showDashboard and barstate.islast
    table.cell(dash, 0, 0, "GOLDEN CROSS v7.0", text_color=color.white, bgcolor=color.new(#0066FF, 0), text_size=size.large)
    table.cell(dash, 1, 0, inLong ? "🟢 LONG" : "⚪ FLAT", text_color=color.white,
         bgcolor=inLong ? color.new(#00FF41, 20) : color.new(color.gray, 30), text_size=size.large)

    table.cell(dash, 0, 1, "Regime", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    table.cell(dash, 1, 1, goldenCross ? "BULL ✓" : "BEAR ✗", text_color=goldenCross ? color.new(#00FF41, 0) : color.new(#FF0055, 0), bgcolor=color.new(#2D2D2D, 0))

    table.cell(dash, 0, 2, "SMA Fast (" + str.tostring(fastLen) + ")", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    table.cell(dash, 1, 2, str.tostring(smaFast, "#.##"), text_color=color.new(#00FF41, 0), bgcolor=color.new(#2D2D2D, 0))

    table.cell(dash, 0, 3, "SMA Slow (" + str.tostring(slowLen) + ")", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    table.cell(dash, 1, 3, str.tostring(smaSlow, "#.##"), text_color=color.new(#FF6B00, 0), bgcolor=color.new(#2D2D2D, 0))

    spreadPerc = (smaFast - smaSlow) / smaSlow * 100
    table.cell(dash, 0, 4, "Spread Fast-Slow", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    table.cell(dash, 1, 4, str.tostring(spreadPerc, "+#.##") + "%", text_color=spreadPerc >= 0 ? color.new(#00FF41, 0) : color.new(#FF0055, 0), bgcolor=color.new(#2D2D2D, 0))

    if inLong
        currentPnL = (close - entryPrice) / entryPrice * 100
        table.cell(dash, 0, 5, "Entry Price", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
        table.cell(dash, 1, 5, str.tostring(entryPrice, "#.##"), text_color=color.white, bgcolor=color.new(#2D2D2D, 0))
        table.cell(dash, 0, 6, "Current P&L", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
        table.cell(dash, 1, 6, str.tostring(currentPnL, "+#.##") + "%", text_color=currentPnL >= 0 ? color.new(#00FF41, 0) : color.new(#FF0055, 0), bgcolor=color.new(#2D2D2D, 0))

    table.cell(dash, 0, 7, "Equity", text_color=color.white, bgcolor=color.new(#1E1E1E, 0))
    table.cell(dash, 1, 7, str.tostring(strategy.equity, "#.##"), text_color=color.white, bgcolor=color.new(#2D2D2D, 0))

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(ta.crossover(smaFast, smaSlow), "Golden Cross", "🚀 GOLDEN CROSS {{ticker}} @ {{close}}")
alertcondition(ta.crossunder(smaFast, smaSlow), "Death Cross", "💀 DEATH CROSS {{ticker}} @ {{close}}")
